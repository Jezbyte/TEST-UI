            local Track = Instance.new("TextButton")
            Track.Size = UDim2.new(1, -24, 0, 5); Track.Position = UDim2.new(0, 12, 0, 32)
            Track.BackgroundColor3 = Color3.fromRGB(35, 40, 50); Track.Text = ""; Track.AutoButtonColor = false; Track.Parent = SliderFrame
            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local startPercent = (value - min) / (max - min)

            local Fill = Instance.new("Frame")
            Fill.ZIndex = 2; Fill.Size = UDim2.new(startPercent, 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromHSV(0.6 + (startPercent * 0.05), 0.8, 1)
            Fill.Parent = Track
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local Knob = Instance.new("Frame")
            Knob.ZIndex = 3; Knob.AnchorPoint = Vector2.new(0.5, 0.5)
            Knob.Size = UDim2.new(0, 10, 0, 10); Knob.Position = UDim2.new(startPercent, 0, 0.5, 0)
            Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Knob.Parent = Track
            Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
            
            local KnobCore = Instance.new("Frame")
            KnobCore.Size = UDim2.new(0, 4, 0, 4); KnobCore.Position = UDim2.new(0.5, -2, 0.5, -2)
            KnobCore.BackgroundColor3 = Color3.fromRGB(45, 105, 255); KnobCore.Parent = Knob
            Instance.new("UICorner", KnobCore).CornerRadius = UDim.new(1, 0)

            local function updateSlider(inputX)
                local scale = math.clamp((inputX - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                value = math.floor(min + (scale * (max - min)))
                ValueLabel.Text = tostring(value)

                local adaptiveColor = Color3.fromHSV(0.58 + (scale * 0.08), 0.82, 1)
                Fill.BackgroundColor3 = adaptiveColor
                KnobCore.BackgroundColor3 = adaptiveColor

                local tweenInfo = TweenInfo.new(0.06, Enum.EasingStyle.Linear)
                TweenService:Create(Fill, tweenInfo, {Size = UDim2.new(scale, 0, 1, 0)}):Play()
                
                local targetKnobSize = isDragging and 14 or 10
                TweenService:Create(Knob, tweenInfo, {
                    Position = UDim2.new(scale, 0, 0.5, 0),
                    Size = UDim2.new(0, targetKnobSize, 0, targetKnobSize)
                }):Play()

                pcall(callback, value)
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    if isDragging then return end
                    isDragging = true
                    
                    TweenService:Create(Track, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(45, 52, 68)}):Play()
                    TweenService:Create(ValueLabel, TweenInfo.new(0.1), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
                    updateSlider(input.Position.X)

                    local dragConnection
                    dragConnection = RunService.RenderStepped:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then
                            isDragging = false
                            dragConnection:Disconnect()
                            
                            TweenService:Create(Track, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 40, 50)}):Play()
                            TweenService:Create(ValueLabel, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(45, 145, 255)}):Play()
                            TweenService:Create(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 10, 0, 10)}):Play()
                            return
                        end
                        updateSlider(input.Position.X)
                    end)
                end
            end)
        end

        return Elements
    end

    return Window
end

return Library
